let warehouses = int(coalesce(env_nil('WAREHOUSES'), 1))
let districts  = int(coalesce(env_nil('DISTRICTS'), 10))
let customers  = int(coalesce(env_nil('CUSTOMERS'), 300))
let orders     = int(coalesce(env_nil('ORDERS'), 300))
let stock      = int(coalesce(env_nil('STOCK'), 1000))
let items      = int(coalesce(env_nil('ITEMS'), 1000))
let batch_size = int(coalesce(env_nil('BATCH_SIZE'), 100))
let ol_batch   = int(coalesce(env_nil('OL_BATCH'), 100))

expect {
  error_rate < 1
}

up {
  create_warehouse(type: exec) `{"create": "warehouse"}`

  create_district(type: exec) `{"create": "district"}`

  create_customer(type: exec) `{"create": "customer"}`

  create_history(type: exec) `{"create": "history"}`

  create_oorder(type: exec) `{"create": "oorder"}`

  create_new_order(type: exec) `{"create": "new_order"}`

  create_order_line(type: exec) `{"create": "order_line"}`

  create_item(type: exec) `{"create": "item"}`

  create_stock(type: exec) `{"create": "stock"}`

  create_nation(type: exec) `{"create": "nation"}`

  create_region(type: exec) `{"create": "region"}`

  create_supplier(type: exec) `{"create": "supplier"}`

  create_idx_customer_name(type: exec) `{"createIndexes": "customer", "indexes": [{"key": {"c_w_id": 1, "c_d_id": 1, "c_last": 1, "c_first": 1}, "name": "idx_customer_name"}]}`

  create_idx_oorder_customer(type: exec) `{"createIndexes": "oorder", "indexes": [{"key": {"o_w_id": 1, "o_d_id": 1, "o_c_id": 1, "o_id": -1}, "name": "idx_oorder_customer"}]}`

  create_idx_district_pk(type: exec) `{"createIndexes": "district", "indexes": [{"key": {"d_w_id": 1, "d_id": 1}, "name": "idx_district_pk", "unique": true}]}`

  create_idx_new_order_pk(type: exec) `{"createIndexes": "new_order", "indexes": [{"key": {"no_w_id": 1, "no_d_id": 1, "no_o_id": 1}, "name": "idx_new_order_pk", "unique": true}]}`

  create_idx_stock_pk(type: exec) `{"createIndexes": "stock", "indexes": [{"key": {"s_w_id": 1, "s_i_id": 1}, "name": "idx_stock_pk", "unique": true}]}`

  create_idx_order_line_delivery(type: exec) `{"createIndexes": "order_line", "indexes": [{"key": {"ol_delivery_d": 1}, "name": "idx_order_line_delivery"}]}`

  create_idx_oorder_carrier(type: exec) `{"createIndexes": "oorder", "indexes": [{"key": {"o_carrier_id": 1}, "name": "idx_oorder_carrier"}]}`
}

seed {
  populate_region(type: exec) `{"insert": "region", "documents": [
      {"_id": 0, "r_regionkey": 0, "r_name": "AFRICA", "r_comment": "ref"},
      {"_id": 1, "r_regionkey": 1, "r_name": "AMERICA", "r_comment": "ref"},
      {"_id": 2, "r_regionkey": 2, "r_name": "ASIA", "r_comment": "ref"},
