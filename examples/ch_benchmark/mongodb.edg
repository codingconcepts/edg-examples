      {"_id": 7, "n_nationkey": 7, "n_name": "GERMANY", "n_regionkey": 3, "n_comment": ""},
      {"_id": 8, "n_nationkey": 8, "n_name": "INDIA", "n_regionkey": 2, "n_comment": ""},
