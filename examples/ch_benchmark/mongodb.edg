      {"_id": 4, "r_regionkey": 4, "r_name": "MIDDLE EAST", "r_comment": "ref"}
    ]}`

  populate_nation(type: exec) `{"insert": "nation", "documents": [
      {"_id": 0, "n_nationkey": 0, "n_name": "ALGERIA", "n_regionkey": 0, "n_comment": ""},
      {"_id": 1, "n_nationkey": 1, "n_name": "ARGENTINA", "n_regionkey": 1, "n_comment": ""},
